{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Marble Documentation",
  "description": "Documentation for Marble, the simple headless CMS for writers and developers.",
  "colors": {
    "primary": "#584dff",
    "light": "#7b73ff",
    "dark": "#5b4ffc"
  },
  "background": {
    "decoration": "windows"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "favicon": "/favicon.svg",
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude",
      {
        "title": "Open in T3 Chat",
        "description": "Ask questions about this page",
        "icon": "https://t3.chat/favicon.ico",
        "href": {
          "base": "https://t3.chat/new",
          "query": [
            {
              "key": "q",
              "value": "Read from https://docs.marblecms.com/$path so I can ask questions about it."
            }
          ]
        }
      },
      "mcp"
    ]
  },
  "redirects": [
    { "source": "/guides/introduction", "destination": "/introduction" },
    { "source": "/guides/quickstart", "destination": "/quickstart" },
    { "source": "/guides/sdk", "destination": "/tools/sdk" },
    { "source": "/guides/mcp", "destination": "/tools/mcp" },
    { "source": "/guides/features/:slug*", "destination": "/features/:slug*" },
    {
      "source": "/guides/integrations/:slug*",
      "destination": "/integrations/:slug*"
    },
    { "source": "/guides/recipes/:slug*", "destination": "/recipes/:slug*" },
    { "source": "/api/getting-started", "destination": "/api/quickstart" }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/headless-cms",
              "concepts/workspaces",
              "concepts/content-model"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/editor",
              "features/custom-fields",
              "features/media",
              "features/webhooks",
              "features/import",
              "features/export"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/nextjs",
              "integrations/astro",
              "integrations/tanstack",
              "integrations/framer"
            ]
          },
          {
            "group": "Tools",
            "pages": ["tools/sdk", "tools/mcp"]
          },
          {
            "group": "Recipes",
            "pages": ["recipes/reading-time", "recipes/code-highlighting"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "https://api.marblecms.com/openapi.json",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "api/introduction",
              "api/quickstart",
              "api/pagination",
              "api/filtering",
              "api/rate-limits",
              "api/types"
            ]
          },
          {
            "group": "Posts",
            "pages": [
              "GET /v1/posts",
              "GET /v1/posts/{identifier}",
              "POST /v1/posts",
              "PATCH /v1/posts/{identifier}",
              "DELETE /v1/posts/{identifier}"
            ]
          },
          {
            "group": "Authors",
            "pages": [
              "GET /v1/authors",
              "GET /v1/authors/{identifier}",
              "POST /v1/authors",
              "PATCH /v1/authors/{identifier}",
              "DELETE /v1/authors/{identifier}"
            ]
          },
          {
            "group": "Categories",
            "pages": [
              "GET /v1/categories",
              "GET /v1/categories/{identifier}",
              "POST /v1/categories",
              "PATCH /v1/categories/{identifier}",
              "DELETE /v1/categories/{identifier}"
            ]
          },
          {
            "group": "Tags",
            "pages": [
              "GET /v1/tags",
              "GET /v1/tags/{identifier}",
              "POST /v1/tags",
              "PATCH /v1/tags/{identifier}",
              "DELETE /v1/tags/{identifier}"
            ]
          },
          {
            "group": "Media",
            "pages": [
              "GET /v1/media",
              "GET /v1/media/{id}",
              "POST /v1/media/upload",
              "PATCH /v1/media/{id}",
              "DELETE /v1/media/{id}"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://marblecms.com/blog",
          "icon": "newspaper"
        },
        {
          "anchor": "Community",
          "href": "https://discord.marblecms.com/",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "footer": {
    "socials": {
      "x": "https://x.com/usemarblecms",
      "github": "https://github.com/usemarble"
    }
  }
}
