---
  import { PRICING_PLANS } from "@marble/utils";
  import Container from "@/components/Container.astro";
  import Button from "@/components/ui/Button.astro";
  import { cn } from "@/lib/utils";
---
<section>
  <Container class="space-y-10 lg:space-y-14 py-20">
    <div class="relative flex flex-col items-center space-y-4">
      <h2
        class="relative text-center text-balance text-2xl tracking-tight md:text-3xl lg:text-4xl max-w-4xl"
      >
        Simple Pricing
      </h2>
      <p class="max-w-prose md:text-lg text-muted-foreground text-center">
        Choose a plan that fits your needs.
      </p>
    </div>

    <!-- Billing Toggle -->
    <div class="flex items-center justify-center gap-3">
      <span class="text-sm text-muted-foreground">Monthly</span>
      <button
        id="billing-toggle"
        type="button"
        role="switch"
        aria-checked="false"
        class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent bg-muted transition-colors duration-200 ease-in-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
      >
        <span
          id="toggle-thumb"
          class="pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out translate-x-0"
        ></span>
      </button>
      <span class="text-sm text-muted-foreground">Yearly</span>
    </div>

    <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
      {PRICING_PLANS.map((plan, index) => (
          <li class={cn("w-full rounded-xl", index === 2 && 'md:col-span-2 xl:col-span-1 md:h-fit xl:h-auto')}>
            <div class={cn("flex flex-col gap-5 rounded-xl bg-white w-full px-4 py-6", index === 2 ? 'md:flex-row md:px-14 md:py-10 xl:py-6 md:justify-center md:gap-20 xl:gap-4 xl:px-4 xl:flex-col min-h-96 md:min-h-fit xl:min-h-96' : 'min-h-96 h-full')}>
              {index === 2 ? (
                <>
                  <div class="flex flex-col gap-5 md:min-w-60 xl:min-w-0">
                    <div class="flex flex-col gap-4">
                      <div class="space-y-1">
                        <h3 class="text-medium text-xl">{plan.title}</h3>
                        <p class="text-muted-foreground text-sm">{plan.description}</p>
                      </div>
                      <div>
                        <p>
                          <span class="font-bold text-2xl" data-plan-id={plan.id} data-monthly={plan.price.monthly} data-yearly={plan.price.yearly}>
                            {plan.price.monthly}
                          </span>{' '}
                          <span class="text-muted-foreground" data-plan-period={plan.id} data-monthly="/ month" data-yearly="/ year">
                            / month
                          </span>
                        </p>
                      </div>
                    </div>
                    <div class="py-4">
                      <Button 
                        href={plan.button.href}
                        target="_blank"
                        class="w-full"
                      >
                        {plan.button.label}
                      </Button>
                    </div>
                  </div>
                  <ul class="flex flex-col gap-2 text-sm">
                    {plan.features.map((feature) => (
                      <li class="flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="size-5 text-emerald-500">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <>
                  <div class="flex flex-col gap-4">
                    <div class="space-y-1">
                      <h3 class="text-medium text-2xl">{plan.title}</h3>
                      <p class="text-muted-foreground text-sm">{plan.description}</p>
                    </div>
                    <div>
                      <p>
                        <span class="font-bold text-2xl" data-plan-id={plan.id} data-monthly={plan.price.monthly} data-yearly={plan.price.yearly}>
                          {plan.price.monthly}
                        </span>{' '}
                        <span class="text-muted-foreground" data-plan-period={plan.id} data-monthly="/ month" data-yearly="/ year">
                          / month
                        </span>
                      </p>
                    </div>
                  </div>
                  <div class="py-4">
                    <Button 
                      href={plan.button.href}
                      target="_blank"
                      class="w-full"
                      size="sm"
                    >
                      {plan.button.label}
                    </Button>
                  </div>
                  <ul class="flex flex-col gap-2 text-sm">
                    {plan.features.map((feature) => (
                      <li class="flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="size-5 text-emerald-500">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                </>
              )}
            </div>
          </li>
        ))}
    </ul>
  </Container>
</section>

<script>
  function initBillingToggle() {
    const toggle = document.getElementById("billing-toggle");
    const thumb = document.getElementById("toggle-thumb");
    const priceElements = document.querySelectorAll("[data-plan-id]");
    const periodElements = document.querySelectorAll("[data-plan-period]");

    let isYearly = false;

    toggle?.addEventListener("click", () => {
      isYearly = !isYearly;

      // Update toggle appearance
      toggle.setAttribute("aria-checked", String(isYearly));
      if (isYearly) {
        thumb?.classList.add("translate-x-5");
        thumb?.classList.remove("translate-x-0");
        toggle.classList.add("bg-accent");
        toggle.classList.remove("bg-muted");
      } else {
        thumb?.classList.remove("translate-x-5");
        thumb?.classList.add("translate-x-0");
        toggle.classList.remove("bg-accent");
        toggle.classList.add("bg-muted");
      }

      // Update prices
      for (const el of priceElements) {
        const monthly = el.getAttribute("data-monthly");
        const yearly = el.getAttribute("data-yearly");
        el.textContent = isYearly ? yearly : monthly;
      }

      for (const el of periodElements) {
        const monthly = el.getAttribute("data-monthly");
        const yearly = el.getAttribute("data-yearly");
        el.textContent = isYearly ? yearly : monthly;
      }
    });
  }

  // Initialize on first load
  initBillingToggle();

  // Re-initialize after page transitions
  document.addEventListener("astro:after-swap", initBillingToggle);
</script>
