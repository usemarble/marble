---
  import { SITE } from "@/lib/constants/site";
  import {
    buildSiteJsonLd,
    buildSiteNavigationJsonLd,
    jsonLd,
  } from "@/lib/seo";
  import "@/styles/globals.css";
  import { Font } from "astro:assets";
  import { getSecret } from "astro:env/server";
  import { ClientRouter } from "astro:transitions";

  interface Props {
    title: string;
    description: string;
    image?: string;
    imageAlt?: string;
    canonical?: string;
    noindex?: boolean;
    structuredData?: unknown;
    ogType?: "website" | "article";
    publishedTime?: string;
    modifiedTime?: string;
    articleAuthors?: string[];
  }

  const DEFAULT_IMAGE = "/og.webp";

  const {
    title,
    description,
    image = DEFAULT_IMAGE,
    imageAlt,
    canonical,
    noindex = false,
    structuredData,
    ogType = "website",
    publishedTime,
    modifiedTime,
    articleAuthors = [],
  } = Astro.props;

  const isDefaultImage = image === DEFAULT_IMAGE;
  const resolvedImageAlt = imageAlt ?? title;

  const canonicalURL = canonical
    ? new URL(canonical, Astro.site)
    : new URL(Astro.url.pathname, Astro.site);
  const imageURL = new URL(image, Astro.site);
  const robotsContent = noindex
    ? "noindex, nofollow"
    : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";

  const databuddyClientId = getSecret("DATABUDDY_CLIENT_ID");
  const siteStructuredData = buildSiteJsonLd({
    title: SITE.TITLE,
    description: SITE.DESCRIPTION,
    url: SITE.URL,
    twitterUrl: SITE.TWITTER_URL,
    githubUrl: SITE.GITHUB_URL,
    logoUrl: new URL("/logo.svg", SITE.URL).toString(),
  });
  const navigationStructuredData = buildSiteNavigationJsonLd([
    { name: "Pricing", url: new URL("/pricing", SITE.URL).toString() },
    { name: "Blog", url: new URL("/blog", SITE.URL).toString() },
    { name: "Changelog", url: new URL("/changelog", SITE.URL).toString() },
    { name: "Documentation", url: "https://docs.marblecms.com" },
    { name: "Log in", url: new URL("/login", SITE.APP_URL).toString() },
  ]);
---
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<meta name="generator" content={Astro.generator}>

<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96">
<link rel="shortcut icon" href="/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<meta name="apple-mobile-web-app-title" content={SITE.TITLE}>
<meta name="theme-color" content="#ffffff">
<link rel="manifest" href="/site.webmanifest">

<link rel="canonical" href={canonicalURL}>

<title>{title}</title>
<meta name="title" content={title}>
<meta name="description" content={description}>
<meta name="robots" content={robotsContent}>

<meta property="og:type" content={ogType}>
<meta property="og:url" content={canonicalURL}>
<meta property="og:title" content={title}>
<meta property="og:site_name" content={SITE.TITLE}>
<meta property="og:description" content={description}>
<meta property="og:image" content={imageURL}>
<meta property="og:image:alt" content={resolvedImageAlt}>
{isDefaultImage && (
  <Fragment>
    <meta property="og:image:width" content="4800">
    <meta property="og:image:height" content="2520">
  </Fragment>
)}
<meta property="og:locale" content="en_US">

{ogType === "article" && (
  <Fragment>
    {publishedTime && <meta property="article:published_time" content={publishedTime}>}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime}>}
    {articleAuthors.map((author) => (
      <meta property="article:author" content={author}>
    ))}
  </Fragment>
)}

<meta property="twitter:card" content="summary_large_image">
<meta property="twitter:site" content={SITE.TWITTER_HANDLE}>
<meta property="twitter:creator" content={SITE.TWITTER_HANDLE}>
<meta property="twitter:url" content={canonicalURL}>
<meta property="twitter:title" content={title}>
<meta property="twitter:description" content={description}>
<meta property="twitter:image" content={imageURL}>
<meta property="twitter:image:alt" content={resolvedImageAlt}>

<script
  is:inline
  type="application/ld+json"
  set:html={jsonLd(siteStructuredData)}
/>
<script
  is:inline
  type="application/ld+json"
  set:html={jsonLd(navigationStructuredData)}
/>

{structuredData && (
  <script is:inline type="application/ld+json" set:html={jsonLd(structuredData)} />
)}

<link rel="sitemap" href="/sitemap-index.xml">
<link
  rel="alternate"
  type="application/rss+xml"
  title={title}
  href={new URL('rss.xml', Astro.site)}
>

{databuddyClientId && (
  <script
    is:inline
    src="https://cdn.databuddy.cc/databuddy.js"
    data-client-id={databuddyClientId}
    data-track-attributes="true"
    data-track-web-vitals="true"
    data-track-errors="true"
    data-enable-batching="true"
    crossorigin="anonymous"
    async
  />
)}

<Font cssVariable="--font-geist" preload/>
<Font cssVariable="--font-literata"/>

<ClientRouter/>
