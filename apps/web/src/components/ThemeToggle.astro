<div
  class="theme-toggle inline-flex rounded-full border border-foreground/40 bg-background p-0.5 text-muted-foreground"
  role="group"
  aria-label="Color theme"
  data-theme-toggle
>
  <button
    type="button"
    class="theme-option"
    aria-label="Use light theme"
    aria-pressed="false"
    title="Light theme"
    data-theme-value="light"
  >
    <svg
      aria-hidden="true"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="4"></circle>
      <path
        d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"
      ></path>
    </svg>
  </button>

  <button
    type="button"
    class="theme-option"
    aria-label="Use system theme"
    aria-pressed="false"
    title="System theme"
    data-theme-value="system"
  >
    <svg
      aria-hidden="true"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="3" y="4" width="18" height="13" rx="2"></rect>
      <path d="M8 21h8M12 17v4"></path>
    </svg>
  </button>

  <button
    type="button"
    class="theme-option"
    aria-label="Use dark theme"
    aria-pressed="false"
    title="Dark theme"
    data-theme-value="dark"
  >
    <svg
      aria-hidden="true"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M20.7 15.1A9 9 0 0 1 8.9 3.3a9 9 0 1 0 11.8 11.8Z"></path>
    </svg>
  </button>
</div>

<style>
  .theme-option {
    display: inline-flex;
    width: 2rem;
    height: 2rem;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    color: inherit;
    transition:
      color 200ms ease,
      background-color 200ms ease;
  }

  .theme-option:hover {
    color: var(--foreground);
  }

  .theme-option:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .theme-option[aria-pressed="true"] {
    background: var(--foreground);
    color: var(--background);
  }

  .theme-option svg {
    width: 1rem;
    height: 1rem;
  }
</style>

<script>
  type Theme = "light" | "system" | "dark";

  const storageKey = "theme";
  const systemTheme = window.matchMedia("(prefers-color-scheme: dark)");
  let transitionFrame: number | undefined;

  function preventThemeTransitions() {
    const root = document.documentElement;
    root.classList.add("theme-changing");

    if (transitionFrame !== undefined) {
      window.cancelAnimationFrame(transitionFrame);
    }

    transitionFrame = window.requestAnimationFrame(() => {
      transitionFrame = window.requestAnimationFrame(() => {
        root.classList.remove("theme-changing");
        transitionFrame = undefined;
      });
    });
  }

  function isTheme(value: string | undefined | null): value is Theme {
    return value === "light" || value === "system" || value === "dark";
  }

  function getTheme(): Theme {
    try {
      const storedTheme = window.localStorage.getItem(storageKey);
      if (isTheme(storedTheme)) {
        return storedTheme;
      }
    } catch {
      // Use the theme already applied by the head script.
    }

    const documentTheme = document.documentElement.dataset.theme;
    return isTheme(documentTheme) ? documentTheme : "system";
  }

  function applyTheme(theme: Theme) {
    const isDark =
      theme === "dark" || (theme === "system" && systemTheme.matches);

    if (document.documentElement.classList.contains("dark") !== isDark) {
      preventThemeTransitions();
    }

    document.documentElement.classList.toggle("dark", isDark);
    document.documentElement.dataset.theme = theme;

    document
      .querySelector('meta[name="theme-color"]')
      ?.setAttribute("content", isDark ? "#10100f" : "#fafaf9");

    for (const option of document.querySelectorAll<HTMLButtonElement>(
      "[data-theme-value]"
    )) {
      option.setAttribute(
        "aria-pressed",
        String(option.dataset.themeValue === theme)
      );
    }
  }

  function setTheme(theme: Theme) {
    try {
      window.localStorage.setItem(storageKey, theme);
    } catch {
      // The selected theme still applies for the current page.
    }

    applyTheme(theme);
  }

  function initThemeToggle() {
    applyTheme(getTheme());

    for (const toggle of document.querySelectorAll<HTMLElement>(
      "[data-theme-toggle]:not([data-initialized])"
    )) {
      toggle.dataset.initialized = "true";
      toggle.addEventListener("click", (event) => {
        const option = (event.target as Element).closest<HTMLButtonElement>(
          "[data-theme-value]"
        );
        const theme = option?.dataset.themeValue;

        if (isTheme(theme)) {
          setTheme(theme);
        }
      });
    }
  }

  systemTheme.addEventListener("change", () => {
    if (getTheme() === "system") {
      applyTheme("system");
    }
  });

  initThemeToggle();
  document.addEventListener("astro:page-load", initThemeToggle);
</script>
