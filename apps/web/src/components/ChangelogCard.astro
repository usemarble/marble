---
  import type { CollectionEntry } from "astro:content";

  interface Props {
    entry: CollectionEntry<"changelog">;
  }

  const { entry } = Astro.props as Props;
  const { title, description, publishedAt, slug, tags } = entry.data;

  const formattedDate = new Date(publishedAt).toLocaleDateString("en-US", {
    day: "2-digit",
    month: "long",
    year: "numeric",
    timeZone: "UTC",
  });
---
<li
  class="relative pl-8 md:grid md:grid-cols-[11rem_minmax(0,1fr)] md:items-start md:gap-7 md:pl-0"
>
  <div
    aria-hidden="true"
    class="absolute top-1.5 left-0 size-3 rounded-full bg-primary ring-4 ring-background md:left-[10.625rem]"
  ></div>
  <time
    datetime={publishedAt.toISOString()}
    class="mb-3 block text-muted-foreground text-sm md:pt-1"
  >
    {formattedDate}
  </time>
  <a href={`/changelog/${slug}`} class="group px-5 transition-colors md:px-6">
    <div class="flex flex-col gap-4">
      <div class="space-y-2">
        <h2
          class="text-xl font-medium leading-snug transition-colors group-hover:text-primary"
        >
          {title}
        </h2>
        <p class="text-muted-foreground text-sm leading-relaxed md:text-base">
          {description}
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        {tags.map((tag) => (
          <span class="rounded-md bg-secondary px-2 py-0.5 text-muted-foreground text-xs">
            #
            {tag.name}
          </span>
        ))}
      </div>
    </div>
  </a>
</li>
