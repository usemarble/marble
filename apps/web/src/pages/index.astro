---
  import { Image } from "astro:assets";
  import { YOUTUBE_VIDEO_ID } from "@marble/utils";
  import heroImage from "@/assets/images/hero.png";
  import Container from "@/components/Container.astro";
  import Pricing from "@/components/sections/Pricing.astro";
  import AccordionItem from "@/components/ui/AccordionItem.astro";
  import ButtonComponent from "@/components/ui/Button.astro";
  import Layout from "@/layouts/Layout.astro";
  import { FAQs } from "@/lib/constants/faqs";
  import { FEATURES, REVIEWS, USERS } from "@/lib/constants/landing";
  import { SITE } from "@/lib/constants/site";
  import { REGISTER_URL, TRACKING_EVENTS } from "@/lib/constants/tracking";
  import { buildFaqJsonLd } from "@/lib/seo";
  import { HERO } from "@/lib/site";
  import { cn } from "@/lib/utils";

  const YOUTUBE_WATCH_URL = `https://www.youtube.com/watch?v=${YOUTUBE_VIDEO_ID}`;
  const structuredData = buildFaqJsonLd(FAQs);
---
<Layout
  title={`${SITE.TITLE} - Super Simple Headless CMS`}
  description={SITE.DESCRIPTION}
  structuredData={structuredData}
>
  <div>
    <!-- Hero section -->
    <section>
      <div class="flex h-full flex-col justify-center">
        <Container
          class="py-24 md:py-28 w-full lg:py-36 flex flex-col gap-14 md:gap-28"
        >
          <div class="flex flex-col gap-8">
            <div class="relative mx-auto text-center flex flex-col gap-6">
              <h1
                class="relative text-4xl md:text-5xl max-w-[25ch] font-medium mx-auto tracking-tight"
              >
                {HERO.title}
              </h1>
              <p class="mx-auto max-w-[50ch] md:text-lg text-muted-foreground">
                {HERO.subtitle}
              </p>
            </div>
            <div
              class="flex flex-col sm:flex-row w-full items-center justify-center gap-4"
            >
              <ButtonComponent
                href={REGISTER_URL}
                target="_blank"
                class="w-full sm:w-auto"
                data-track={TRACKING_EVENTS.signupClicked}
                data-context="home_hero"
                data-label="Publish your first post"
              >
                Publish your first post
              </ButtonComponent>
              <ButtonComponent
                href={YOUTUBE_WATCH_URL}
                target="_blank"
                variant="secondary"
                class="w-full sm:w-auto"
              >
                Watch Demo
              </ButtonComponent>
            </div>
          </div>
          <div class="w-full overflow-hidden rounded-[8px] aspect-video">
            <!-- <iframe
                src={YOUTUBE_EMBED_URL}
                title="Marble CMS - Super Simple Headless CMS"
                allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                class="w-full h-full"
              /> -->
            <Image
              src={heroImage}
              inferSize
              alt="marble dashboard showing a chart and list of media files"
              loading="eager"
            />
          </div>
        </Container>
      </div>
    </section>

    <!--  Social Proof -->
    <section>
      <Container class="py-12">
        <div class="sr-only">
          <h2
            class="relative text-center text-balance text-2xl tracking-tight md:text-3xl lg:text-4xl max-w-4xl"
          >
            Trusted by
          </h2>
        </div>
        <ul
          class="grid gap-4"
          style="grid-template-columns: repeat(auto-fit, minmax(min(100%, 160px), 1fr));"
        >
          {USERS.map((user) => (
              <li class="h-24 rounded-xl bg-surface transition-colors">
                <a
                  href={user.url + "?utm_source=marble"}
                  target="_blank"
                  rel="noopener"
                  class={cn(
                    "flex items-center justify-center h-full w-full rounded-xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary",
                    user.showWordmark && "gap-2"
                  )}
                >
                  <user.component class="h-8 w-auto" />
                  {user.showWordmark && (
                    <span class="text-base font-medium">{user.name}</span>
                  )}
                  {!user.showWordmark && (
                    <span class="text-base font-medium sr-only">{user.name}</span>
                  )}
                </a>
              </li>
            ))}
        </ul>
      </Container>
    </section>

    <!-- Features section -->
    <section>
      <Container class="space-y-10 lg:space-y-14 py-20">
        <div class="relative flex flex-col items-center space-y-3 text-balance">
          <h2
            class="relative text-center text-balance text-acc text-2xl tracking-tight md:text-3xl lg:text-4xl max-w-4xl"
          >
            Everything you need to publish.
          </h2>
          <!-- <p class="max-w-prose md:text-lg text-muted-foreground text-center">
              Everything you need to manage your content.
            </p> -->
        </div>

        <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6">
          {FEATURES.map((feature, index) => (
              <li class="bg-surface p-3 rounded-[16px] flex flex-col gap-4 h-full">
                <div class="overflow-hidden w-full rounded-lg bg-background">
                  <Image
                    src={feature.image}
                    alt={feature.title}
                    inferSize
                    class="w-full h-auto"
                  />
                </div>
                <div class="flex-1 text-left">
                  <h3 class="text-xl mb-2 font-medium">
                    {feature.title}
                  </h3>
                  <p class="text-muted-foreground text-sm text-balance">
                    {feature.description}
                  </p>
                </div>
              </li>
            ))}
        </ul>
      </Container>
    </section>

    <!-- Reviews section -->
    <section>
      <Container class="space-y-10 lg:space-y-14 pt-12 pb-20">
        <div class="relative flex flex-col items-center space-y-3 text-balance">
          <h2
            class="relative text-center text-balance text-2xl tracking-tight md:text-3xl lg:text-4xl max-w-4xl"
          >
            What people are saying
          </h2>
        </div>

        <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {REVIEWS.map((review) => (
              <li>
                <a href={review.link} target="_blank" class="bg-surface p-6 rounded-xl flex flex-col justify-between gap-8 h-full">
                  <p class="text-muted-foreground leading-relaxed">
                    {review.text}
                  </p>
                  <div class="flex items-center gap-3">
                    <div class="size-10 rounded-full bg-muted flex items-center justify-center text-xs font-medium text-muted-foreground">
                      <Image
                        src={review.avatar}
                        alt={review.author}
                        class="w-full h-auto rounded-full"
                        width={40}
                        height={40}
                      />
                    </div>
                    <div class="space-y-0.5">
                      <p class="font-medium text-sm text-foreground">
                        {review.author}
                      </p>
                      <p class="text-muted-foreground text-xs">
                        {review.role}
                      </p>
                    </div>
                  </div>
                </a>
              </li>
            ))}
        </ul>
      </Container>
    </section>

    <!-- Pricing section -->
    <Pricing/>

    <!-- FAQ -->
    <section>
      <Container class="pt-12 pb-20">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-20">
          <div
            class="flex flex-col items-center lg:items-start space-y-4 text-center lg:text-left"
          >
            <h2
              class="relative text-center text-balance text-2xl tracking-tight md:text-3xl lg:text-4xl lg:text-left  md max-w-4xl"
            >
              Frequently asked Questions
            </h2>
            <p
              class="max-w-prose md:text-lg text-muted-foreground text-balance"
            >
              Answers to common questions about marblecms.
            </p>
          </div>

          <div class="lg:col-span-2">
            {FAQs.map(faq => (
              <AccordionItem name="details" title={faq.question}>
                <p class="text-sm faq-answer text-muted-foreground pb-2" set:html={faq.answer} />
              </AccordionItem>
            ))}
          </div>
        </div>
      </Container>
    </section>

    <!-- CTA -->
    <section>
      <Container class="py-12 md:py-20">
        <div
          class="flex w-full flex-col items-center space-y-6 rounded-xl bg-surface px-6 py-10 md:px-10 md:py-14"
        >
          <div class="space-y-4 text-center">
            <h2
              class="relative text-center text-balance text-2xl tracking-tight md:text-3xl lg:text-4xl max-w-4xl"
            >
              Try Marble today.
            </h2>
            <p
              class="mx-auto max-w-2xl text-muted-foreground md:text-lg text-balance"
            >
              A simpler way to publish articles and manage your blog.
            </p>
          </div>

          <div
            class="flex flex-col sm:flex-row w-full items-center justify-center gap-4"
          >
            <ButtonComponent
              href={REGISTER_URL}
              target="_blank"
              class="w-full sm:w-auto"
              data-track={TRACKING_EVENTS.signupClicked}
              data-context="home_bottom_cta"
              data-label="Try Marble for free"
            >
              Try Marble for free
            </ButtonComponent>
            <ButtonComponent
              href={YOUTUBE_WATCH_URL}
              variant="secondary"
              class="w-full sm:w-auto"
            >
              Watch Demo
            </ButtonComponent>
          </div>
        </div>
      </Container>
    </section>
  </div>
</Layout>
